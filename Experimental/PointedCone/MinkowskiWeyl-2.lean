      ∃ D : PointedCone 𝕜 N, D.DualFG p ∧ D ⊓ Submodule.span 𝕜 (M := N) C = C :=
  exists_dualfg_inf_submodule p hC (submodule_span_fg hC) Submodule.subset_span

