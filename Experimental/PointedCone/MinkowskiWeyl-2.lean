  obtain hSv | ⟨y, hy⟩ := {y ∈ C | p y w < 0 ∧ p y v < 0}.eq_empty_or_nonempty
  · simp +contextual only [Set.eq_empty_iff_forall_notMem, Set.mem_setOf_eq, not_and, not_lt] at hSv
    refine ⟨0, zero_mem _, v, fun x hx => ?_, zero_add _⟩
