      ∃ D : PointedCone 𝕜 N, D.DualFG p ∧ ∃ S : Subspace 𝕜 N, S.FG ∧ D ⊓ S = C := by
  obtain ⟨D, hdualfg, hD⟩ := exists_dualfg_inf_span p hC
